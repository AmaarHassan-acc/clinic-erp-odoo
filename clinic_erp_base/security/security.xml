<odoo>
    <record id="module_category_clinic_erp" model="ir.module.category">
        <field name="name">Clinic ERP</field>
        <field name="sequence">20</field>
    </record>
    <record id="group_clinic_receptionist" model="res.groups">
        <field name="name">Receptionist</field>
        <field name="category_id" ref="module_category_clinic_erp"/>
    </record>
    <record id="group_clinic_doctor" model="res.groups">
        <field name="name">Doctor</field>
        <field name="category_id" ref="module_category_clinic_erp"/>
    </record>
    <record id="group_clinic_manager" model="res.groups">
        <field name="name">Clinic Manager</field>
        <field name="category_id" ref="module_category_clinic_erp"/>
        <field name="implied_ids" eval="[(4, ref('group_clinic_receptionist')), (4, ref('group_clinic_doctor'))]"/>
    </record>
</odoo>
