<odoo>
    <record id="view_clinic_staff_list" model="ir.ui.view">
        <field name="name">clinic.staff.list</field><field name="model">clinic.staff</field>
        <field name="arch" type="xml"><list><field name="name"/><field name="staff_type"/><field name="position"/><field name="main_role"/><field name="department"/><field name="specialty"/><field name="room_id"/><field name="active"/></list></field>
    </record>
    <record id="view_clinic_staff_form" model="ir.ui.view">
        <field name="name">clinic.staff.form</field><field name="model">clinic.staff</field>
        <field name="arch" type="xml"><form><sheet><group><field name="name"/><field name="user_id"/><field name="staff_type"/><field name="position"/><field name="main_role"/><field name="department"/><field name="specialty"/><field name="gender"/><field name="languages"/><field name="phone"/><field name="email"/><field name="license_no"/><field name="room_id"/><field name="active"/></group><field name="notes"/></sheet><chatter/></form></field>
    </record>
    <record id="action_clinic_staff" model="ir.actions.act_window">
        <field name="name">Medical Staff</field><field name="res_model">clinic.staff</field><field name="view_mode">list,form</field>
    </record>
</odoo>
