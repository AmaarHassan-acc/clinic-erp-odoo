<odoo>
    <record id="view_clinic_appointment_list" model="ir.ui.view"><field name="name">clinic.appointment.list</field><field name="model">clinic.appointment</field><field name="arch" type="xml"><list><field name="name"/><field name="appointment_date"/><field name="appointment_time"/><field name="patient_id"/><field name="doctor_id"/><field name="department"/><field name="room_id"/><field name="state"/></list></field></record>
    <record id="view_clinic_appointment_form" model="ir.ui.view"><field name="name">clinic.appointment.form</field><field name="model">clinic.appointment</field><field name="arch" type="xml"><form><header><button name="action_send_to_queue" type="object" string="Send to Queue" class="btn-primary"/><button name="action_cancel" type="object" string="Cancel"/><field name="state" widget="statusbar"/></header><sheet><group><field name="name"/><field name="patient_id"/><field name="doctor_id"/><field name="department"/><field name="room_id"/><field name="appointment_date"/><field name="appointment_time"/><field name="service_ids" widget="many2many_tags"/></group><field name="concerns"/><field name="visit_id"/></sheet><chatter/></form></field></record>
    <record id="view_clinic_appointment_calendar" model="ir.ui.view"><field name="name">clinic.appointment.calendar</field><field name="model">clinic.appointment</field><field name="arch" type="xml"><calendar date_start="appointment_date" color="doctor_id"><field name="name"/><field name="patient_id"/><field name="doctor_id"/><field name="state"/></calendar></field></record>
    <record id="action_clinic_appointment" model="ir.actions.act_window"><field name="name">Appointments</field><field name="res_model">clinic.appointment</field><field name="view_mode">calendar,list,form</field></record>
</odoo>
