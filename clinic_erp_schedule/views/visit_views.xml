<odoo>
    <record id="view_clinic_visit_list" model="ir.ui.view"><field name="name">clinic.visit.list</field><field name="model">clinic.visit</field><field name="arch" type="xml"><list><field name="name"/><field name="visit_date"/><field name="visit_time"/><field name="patient_id"/><field name="doctor_id"/><field name="department"/><field name="room_id"/><field name="state"/></list></field></record>
    <record id="view_clinic_visit_form" model="ir.ui.view"><field name="name">clinic.visit.form</field><field name="model">clinic.visit</field><field name="arch" type="xml"><form><header><button name="action_with_doctor" type="object" string="Send to Doctor" class="btn-primary"/><button name="action_complete" type="object" string="Complete"/><button name="action_cancel" type="object" string="Cancel"/><field name="state" widget="statusbar"/></header><sheet><group><field name="name"/><field name="appointment_id"/><field name="patient_id"/><field name="doctor_id"/><field name="department"/><field name="room_id"/><field name="visit_date"/><field name="visit_time"/><field name="service_ids" widget="many2many_tags"/></group><notebook><page string="Clinical Chart"><field name="diagnosis"/><field name="clinical_notes"/></page></notebook></sheet><chatter/></form></field></record>
    <record id="action_clinic_visit" model="ir.actions.act_window"><field name="name">Visits</field><field name="res_model">clinic.visit</field><field name="view_mode">list,form</field></record>
</odoo>
